{
  "name": "cadence",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspace",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "moby": false
    }
  },
  "postCreateCommand": "pip install -e . && pip install -r requirements.txt",
  "extensions": [
    "ms-python.python"
  ]
}
